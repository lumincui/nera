{
  "name": "nera",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "nera",
      "workspaces": [
        "apps/nera-server",
        "apps/sidecar"
      ]
    },
    "apps/nera-server": {
      "name": "@nera/server"
    },
    "apps/sidecar": {
      "name": "@nera/sidecar",
      "bin": {
        "nera-sidecar": "src/cli.js"
      }
    },
    "node_modules/@nera/server": {
      "resolved": "apps/nera-server",
      "link": true
    },
    "node_modules/@nera/sidecar": {
      "resolved": "apps/sidecar",
      "link": true
    }
  }
}
